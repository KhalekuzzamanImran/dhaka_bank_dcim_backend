DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-this-secret-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgresql://dcim:dcim@db:5432/dcim
POSTGRES_DB=dcim
POSTGRES_USER=dcim
POSTGRES_PASSWORD=dcim
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# Email notification
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=dcim-alerts@test.local

# Future SMTP production example
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=dcim-alerts@example.com
# EMAIL_HOST_PASSWORD=change-me
# DEFAULT_FROM_EMAIL=dcim-alerts@example.com

# SMS notification
SMS_BACKEND=console
SMS_API_URL=
SMS_API_KEY=
SMS_DEFAULT_SENDER=DCIM
SMS_TIMEOUT_SECONDS=15

# Future SMS production example
# SMS_BACKEND=http
# SMS_API_URL=https://sms-gateway.example.com/send
# SMS_API_KEY=change-me
# SMS_DEFAULT_SENDER=DCIM

# Keep this stable in production; changing it makes encrypted SNMP secrets unreadable.
FIELD_ENCRYPTION_KEY=change-me-long-random-field-encryption-key
SNMP_CELERY_QUEUE=snmp
SNMP_ENQUEUE_INTERVAL_SECONDS=30
SNMP_ENQUEUE_LIMIT=200

# Polling and trap receiver
POLLING_SCHEDULER_INTERVAL_SECONDS=5
POLLING_SCHEDULER_LIMIT=200
SNMP_CELERY_QUEUE=snmp_normal
MODBUS_CELERY_QUEUE=modbus_normal
SNMP_TRAP_LISTEN_HOST=0.0.0.0
SNMP_TRAP_LISTEN_PORT=1162
FIELD_ENCRYPTION_KEY=change-this-to-a-long-stable-secret-before-production
